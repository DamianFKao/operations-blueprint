{
  "name": "operations-blueprint",
  "version": "0.4.0",
  "description": "Turn a small custom manufacturer's answers into a tailored, foundation-first operations plan and a runnable starter repo. Deterministic, no LLM.",
  "license": "MIT",
  "author": "Damian Kao",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist", "src", "README.md", "LICENSE"],
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js && tsc --emitDeclarationOnly",
    "example": "node examples/generate.mjs"
  },
  "keywords": [
    "manufacturing",
    "operations",
    "quoting",
    "estimating",
    "erp",
    "small-business",
    "code-generation",
    "scaffolding"
  ],
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
