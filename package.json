{
  "name": "operations-blueprint",
  "version": "0.5.0",
  "description": "Turn a small custom manufacturer's answers into a tailored, foundation-first operations plan and a runnable starter repo. Deterministic, no LLM.",
  "license": "MIT",
  "author": "Damian Kao",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "operations-blueprint": "bin/operations-blueprint.mjs"
  },
  "files": ["dist", "src", "bin", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20.11"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/DamianFKao/operations-blueprint.git"
  },
  "homepage": "https://damiankao.com/blueprint",
  "bugs": "https://github.com/DamianFKao/operations-blueprint/issues",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --format=esm --platform=node --outfile=dist/index.js && tsc --emitDeclarationOnly",
    "prepare": "npm run build",
    "pretest": "npm run build",
    "test": "node --test test/*.test.mjs",
    "example": "node examples/generate.mjs",
    "blueprints": "node scripts/build-blueprints.mjs"
  },
  "keywords": [
    "manufacturing",
    "operations",
    "quoting",
    "estimating",
    "erp",
    "small-business",
    "code-generation",
    "scaffolding"
  ],
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0"
  }
}
